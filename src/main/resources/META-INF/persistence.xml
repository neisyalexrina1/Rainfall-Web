<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

  <persistence-unit name="RainfallForecastPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <!-- 6 entity classes -->
    <class>model.User</class>
    <class>model.Station</class>
    <class>model.RainfallData</class>
    <class>model.ForecastLog</class>
    <class>model.Order</class>
    <class>model.ServicePackage</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>

    <properties>
      <!-- JDBC -->
      <property name="jakarta.persistence.jdbc.driver"   value="org.postgresql.Driver"/>
      <property name="jakarta.persistence.jdbc.url"      value="jdbc:postgresql://db.cokvgdzywatnxqkckwjb.supabase.co:5432/postgres"/>
      <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
      <property name="jakarta.persistence.jdbc.password" value="Dominhgiabao12"/>
      <!-- Hibernate -->
      <property name="hibernate.dialect"        value="org.hibernate.dialect.PostgreSQLDialect"/>
      <property name="hibernate.hbm2ddl.auto"   value="none"/>
      <property name="hibernate.show_sql"       value="true"/>
    </properties>
  </persistence-unit>

</persistence>
